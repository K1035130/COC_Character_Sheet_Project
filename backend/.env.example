# Copy this file to .env (or export these as real environment variables) before running the backend locally.
# .env itself is gitignored - never commit real secrets.

# MongoDB Atlas connection string. Use a distinct database name for local dev vs prod,
# e.g. mongodb+srv://<user>:<password>@<cluster>.mongodb.net/coc_sheets_dev
MONGODB_URI=

# HS256 signing secret for JWTs. Must be at least 32 bytes long.
JWT_SECRET=

# Origin the backend will accept CORS requests from during local development.
CORS_ALLOWED_ORIGIN=http://localhost:5173
